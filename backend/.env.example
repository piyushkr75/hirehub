# Server
PORT=5000

# MongoDB connection string (NO database name at the end, and recommended: no trailing slash)
# Example (Atlas): mongodb+srv://username:password@cluster0.xxxxx.mongodb.net
# Example (Local): mongodb://127.0.0.1:27017
DATABASE_CONNECTION_URL=YOUR_MONGODB_CONNECTION_STRING

# JWT secret used for auth tokens
JWT_SECRET=YOUR_JWT_SECRET

# Cloudinary credentials (used for file uploads)
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

